@page "/contracts"

@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using oedibud.Models
@using oedibud.Data
@inject IDbContextFactory<BudgetDbContext> DbFactory

<PageTitle>Arbeitsverträge</PageTitle>


<h3 class="text-primary-emphasis">Arbeitsverträge</h3>
<hr />
<div class="mb-3">
    <label>Mitarbeiter</label>
    <select class="form-control mb-2" @bind="newContract.EmployeeId">
        <option value="0">-- auswählen --</option>
        @foreach (var e in employees)
        {
            <option value="@e.Id">@e.Name</option>
        }
    </select>

    <label>Start</label>
    <InputDate class="form-control mb-2" @bind-Value="newContract.Start" />

    <label>Ende</label>
    <InputDate class="form-control mb-2" @bind-Value="newContract.End" />

    <label>Stellenanteil</label>
    
    <div class="input-group">
        <input type="number"
               class="form-control"
               step="1"
               min="0" max="100"
               @bind="newContract.FtePercent" />
        <span class="input-group-text">%</span>
    </div>
    @* <input type="number" step="1" min="0" max="100" class="form-control mb-2" @bind="newContract.FtePercent" /> *@


    <button class="btn btn-primary mt-2" @onclick="AddContract">Vertrag hinzufügen</button>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info">@message</div>
}

<hr />

@if (contracts.Count == 0)
{
    <p>Keine Arbeitsverträge vorhanden.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Mitarbeiter</th>
                <th>Start</th>
                <th>Ende</th>
                <th>Stellenanteil</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in contracts)
            {
                <tr>
                    <td>@c.Id</td>
                    @if (editingContractId == c.Id)
                    {
                        <td>@(c.Employee?.Name ?? employees.FirstOrDefault(e => e.Id == c.EmployeeId)?.Name ?? "-")</td>
                        <td><input type="date" class="form-control" @bind="editContractCopy.Start" /></td>
                        <td><input type="date" class="form-control" @bind="editContractCopy.End" /></td>
                        <td>
                            <div class="input-group">
                                <input type="number"
                                       class="form-control"
                                       step="1"
                                       min="0" max="100"
                                       @bind="editContractCopy.FtePercent" />
                                <span class="input-group-text">%</span>
                            </div>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-success me-2" @onclick="() => SaveContract(editContractCopy.Id)">Speichern</button>
                            <button class="btn btn-sm btn-secondary me-2" @onclick="() => CancelEditContract()">Abbrechen</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(c.Id)">@(expanded.Contains(c.Id) ? "Verstecken" : "Projektmittel zuweisen")</button>
                        </td>
                    }
                    else
                    {
                        <td>@(c.Employee?.Name ?? employees.FirstOrDefault(e => e.Id == c.EmployeeId)?.Name ?? "-")</td>
                        <td>@c.Start.ToShortDateString()</td>
                        <td>@c.End.ToShortDateString()</td>
                        <td>@c.FtePercent%</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditContractRow(c)">Bearbeiten</button>
                            <button class="btn btn-danger btn-sm me-2" @onclick="() => DeleteContract(c.Id)">Löschen</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(c.Id)">@(expanded.Contains(c.Id) ? "Verstecken" : "Projektmittel zuweisen")</button>

                        </td>
                    }
                </tr>
                @if (expanded.Contains(c.Id))
                {
                    <tr>
                        <td colspan="7" class="p-0 bg-dark-subtle">
                            <div class="p-3">
                                @if (c.ContractPayments == null || c.ContractPayments.Count == 0)
                                {
                                    <div><em>Keine Projektmittel zugewiesen</em></div>
                                }
                                <table class="table-sm">
                                    <thead>
                                        <tr><th>Projekt</th><th>PM-ID</th><th>Zeitraum</th><th>Betrag</th><th>Gewidmet</th><th>Lohnanteil</th><th>Von</th><th>Bis</th><th></th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cp in c.ContractPayments.OrderByDescending(x => x.Payment?.Start))
                                        {
                                            <tr>
                                                @if (editingContractPaymentIds.Contains(cp.Id))
                                                {
                                                    <td colspan="5">
                                                        <select class="form-control" @bind="editContractPaymentCopies[cp.Id].PaymentId">
                                                            <option value="@editContractPaymentCopies[cp.Id].PaymentId">@($"{payments.FirstOrDefault(p => p.Id == cp.PaymentId)?.Project?.Title ?? "Unbekanntes Projekt"} | PM-{cp.Payment?.Id} | {cp.Payment?.Start.ToShortDateString()} - {cp.Payment?.End.ToShortDateString()} | {cp.Payment?.Amount.ToString("C")} | {(cp.Payment?.DetecatedTo?.ToString() ?? "-")}")</option>
                                                            @foreach (var p in AvailablePaymentsForContract(c))
                                                            {
                                                                <option value="@p.Id">@($"{payments.FirstOrDefault(pa => pa.Id == p.Id)?.Project?.Title ?? "Unbekanntes Projekt"} | PM-{p.Id} | {p.Start.ToShortDateString()} - {p.End.ToShortDateString()} | {p.Amount.ToString("C")} | {(p.DetecatedTo?.ToString() ?? "-")}")</option>
                                                            }
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <div class="input-group">
                                                            <input type="number"
                                                                   class="form-control"
                                                                   step="1"
                                                                   min="0"
                                                                   max="100"
                                                                   @bind="editContractPaymentCopies[cp.Id].SharePercent" />
                                                            <span class="input-group-text">%</span>
                                                        </div>
                                                    </td>
                                                    <td><input type="date" class="form-control" @bind="editContractPaymentCopies[cp.Id].Start" /></td>
                                                    <td><input type="date" class="form-control" @bind="editContractPaymentCopies[cp.Id].End" /></td>
                                                    <td>
                                                        <button class="btn btn-sm btn-success me-1" @onclick="() => SaveContractPayment(cp.Id)">Speichern</button>
                                                        <button class="btn btn-sm btn-secondary" @onclick="() => CancelEditContractPayment(cp.Id)">Abbrechen</button>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td>@(projects.FirstOrDefault(pr => pr.Id == cp.Payment.ProjectId)?.Title ?? "Unbekanntes Projekt")</td>
                                                    <td>@($"PM-{cp.Payment?.Id}")</td>
                                                    <td>@(cp.Payment?.Start.ToShortDateString() ?? "-") - @(cp.Payment?.End.ToShortDateString() ?? "-")</td>
                                                    <td>@(cp.Payment?.Amount.ToString("C") ?? "-")</td>
                                                    <td>@(cp.Payment?.DetecatedTo?.ToString() ?? "-")</td>
                                                    <td>@cp.SharePercent%</td>
                                                    <td>@(cp.Start?.ToShortDateString() ?? "-")</td>
                                                    <td>@(cp.End?.ToShortDateString() ?? "-")</td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditContractPayment(cp)">Bearbeiten</button>
                                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteContractPayment(cp.Id, c.Id)">Entfernen</button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                        <tr>
                                            <td colspan="5">
                                                <select class="form-control" @bind="paymentInputs[c.Id].PaymentId">
                                                    <option value="0">-- auswählen --</option>
                                                    @foreach (var p in AvailablePaymentsForContract(c))
                                                    {
                                                        <option value="@p.Id">@($"{payments.FirstOrDefault(pa => pa.Id == p.Id)?.Project?.Title ?? "Unbekanntes Projekt"} | PM-{p.Id} | {p.Start.ToShortDateString()} - {p.End.ToShortDateString()} | {p.Amount.ToString("C")} | {(p.DetecatedTo?.ToString() ?? "-")}")</option>
                                                    }
                                                </select>
                                            </td>
                                            
                                            <td>
                                                <div class="input-group">
                                                    <input type="number"
                                                           class="form-control"
                                                           step="1"
                                                           min="0"
                                                           max="100"
                                                           @bind="paymentInputs[c.Id].SharePercent" />
                                                    <span class="input-group-text">%</span>
                                                </div>
                                            </td>
                                            <td>
                                                <input type="date" class="form-control" @bind="paymentInputs[c.Id].Start" />
                                            </td>
                                            <td>
                                                <input type="date" class="form-control" @bind="paymentInputs[c.Id].End" />
                                            </td>
                                            <td>
                                                <button class="btn btn-success" @onclick="() => AddContractPayment(c)">Hinzufügen</button>
                                            </td>
                                                
                                        </tr>
                                    </tbody>
                                </table>
                                
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private Contract newContract = new Contract
    {
        Start = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
        End = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(24).AddDays(-1),
        Fte = 1.0f
    };
    private List<Employee> employees = new();
    private List<Project> projects = new();
    private List<Contract> contracts = new();
    private List<Payment> payments = new();
    private string message = string.Empty;

    // UI helpers
    private HashSet<int> expanded = new();

    private class ContractPaymentInput
    {
        public int PaymentId { get; set; }
        public int SharePercent { get; set; } = 100;
        public DateTime? Start { get; set; }
        public DateTime? End { get; set; }
    }

    private Dictionary<int, ContractPaymentInput> paymentInputs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = DbFactory.CreateDbContext();
        employees = await db.Employees.OrderBy(e => e.Name).ToListAsync();
        projects = await db.Projects.OrderByDescending(p => p.Start).ToListAsync();
        payments = await db.Payments.OrderByDescending(p => p.Start).ToListAsync();
        contracts = await db.Contracts
            .Include(c => c.Employee)
            .Include(c => c.ContractPayments)
                .ThenInclude(cp => cp.Payment)
            .OrderByDescending(c => c.Start)
            .ToListAsync();

        paymentInputs = contracts.ToDictionary(c => c.Id, c => new ContractPaymentInput());
    }

    private IEnumerable<Payment> AvailablePaymentsForContract(Contract c)
    {
        // payments that match employee group or have no dedicated group and not already assigned to this contract
        var empGroup = c.Employee?.Group;
        var assignedIds = c.ContractPayments?.Select(x => x.PaymentId).ToHashSet() ?? new HashSet<int>();
        return payments.Where(p => !assignedIds.Contains(p.Id) && (p.DetecatedTo == null || (empGroup != null && p.DetecatedTo == empGroup)));
    }

    private void ToggleExpand(int id)
    {
        if (!expanded.Remove(id))
        {
            expanded.Add(id);
            if (!paymentInputs.ContainsKey(id)) paymentInputs[id] = new ContractPaymentInput();
        }
    }

    private async Task AddContractPayment(Contract c)
    {
        if (!paymentInputs.TryGetValue(c.Id, out var input)) return;
        if (input.PaymentId == 0)
        {
            message = "Bitte eine Projektmittel auswählen.";
            return;
        }
        if (input.SharePercent < 0 || input.SharePercent > 100)
        {
            message = "Anteil muss zwischen 0 und 100 liegen.";
            return;
        }

        try
        {
            using var db = DbFactory.CreateDbContext();
            var cp = new ContractPayment
            {
                ContractId = c.Id,
                PaymentId = input.PaymentId,
                SharePercent = input.SharePercent,
                Start = input.Start,
                End = input.End
            };
            db.Add(cp);
            await db.SaveChangesAsync();

            // update local model
            var loaded = await db.ContractPayments.Include(x => x.Payment).FirstOrDefaultAsync(x => x.Id == cp.Id);
            if (loaded != null)
            {
                var target = contracts.FirstOrDefault(x => x.Id == c.Id);
                if (target != null) target.ContractPayments.Add(loaded);
            }

            message = "Projektmittel zugewiesen.";
            paymentInputs[c.Id] = new ContractPaymentInput();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteContractPayment(int contractPaymentId, int contractId)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.ContractPayments.FindAsync(contractPaymentId);
            if (item != null)
            {
                db.ContractPayments.Remove(item);
                await db.SaveChangesAsync();
                var target = contracts.FirstOrDefault(c => c.Id == contractId);
                if (target != null) target.ContractPayments.RemoveAll(x => x.Id == contractPaymentId);
                message = "Zuweisung entfernt.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task AddContract()
    {
        if (newContract.EmployeeId == 0)
        {
            message = "Bitte einen Mitarbeiter auswählen.";
            return;
        }
        if (newContract.End < newContract.Start)
        {
            message = "Ende darf nicht vor dem Start liegen.";
            return;
        }

        try
        {
            using var db = DbFactory.CreateDbContext();
            var toSave = new Contract
            {
                EmployeeId = newContract.EmployeeId,
                Start = newContract.Start,
                End = newContract.End,
                Fte = newContract.Fte
            };

            db.Contracts.Add(toSave);
            await db.SaveChangesAsync();

            // reload saved contract with navigation
            var saved = await db.Contracts.Include(c => c.Employee).FirstOrDefaultAsync(c => c.Id == toSave.Id);
            if (saved != null) contracts.Insert(0, saved);

            message = "Vertrag gespeichert.";
            newContract = new Contract { Start = DateTime.Today, End = DateTime.Today.AddMonths(1), Fte = 1.0f };
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteContract(int id)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.Contracts.FindAsync(id);
            if (item != null)
            {
                db.Contracts.Remove(item);
                await db.SaveChangesAsync();
                contracts.RemoveAll(c => c.Id == id);
                message = "Vertrag gelöscht.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    // --- Inline edit support ---
    private int? editingContractId = null;
    private Contract editContractCopy = new Contract();

    private HashSet<int> editingContractPaymentIds = new();
    private Dictionary<int, ContractPayment> editContractPaymentCopies = new();

    private void EditContractRow(Contract c)
    {
        editingContractId = c.Id;
        editContractCopy = new Contract
        {
            Id = c.Id,
            EmployeeId = c.EmployeeId,
            Start = c.Start,
            End = c.End,
            Fte = c.Fte
        };
    }

    private void CancelEditContract()
    {
        editingContractId = null;
        editContractCopy = new Contract();
    }

    private async Task SaveContract(int id)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.Contracts.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.Start = editContractCopy.Start;
                dbItem.End = editContractCopy.End;
                dbItem.Fte = editContractCopy.Fte;
                await db.SaveChangesAsync();

                var idx = contracts.FindIndex(x => x.Id == id);
                if (idx >= 0)
                {
                    contracts[idx].Start = dbItem.Start;
                    contracts[idx].End = dbItem.End;
                    contracts[idx].Fte = dbItem.Fte;
                }
                message = "Vertrag gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            CancelEditContract();
        }
    }

    private void EditContractPayment(ContractPayment cp)
    {
        editingContractPaymentIds.Add(cp.Id);
        editContractPaymentCopies[cp.Id] = new ContractPayment
        {
            Id = cp.Id,
            ContractId = cp.ContractId,
            PaymentId = cp.PaymentId,
            SharePercent = cp.SharePercent,
            Start = cp.Start,
            End = cp.End
        };
    }

    private void CancelEditContractPayment(int id)
    {
        editingContractPaymentIds.Remove(id);
        editContractPaymentCopies.Remove(id);
    }

    private async Task SaveContractPayment(int id)
    {
        if (!editContractPaymentCopies.TryGetValue(id, out var copy)) return;
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.ContractPayments.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.SharePercent = copy.SharePercent;
                dbItem.Start = copy.Start;
                dbItem.End = copy.End;
                dbItem.PaymentId = copy.PaymentId;
                await db.SaveChangesAsync();

                // update local model
                foreach (var c in contracts)
                {
                    var idx = c.ContractPayments?.FindIndex(x => x.Id == id) ?? -1;
                    if (idx >= 0)
                    {
                        c.ContractPayments[idx].SharePercent = dbItem.SharePercent;
                        c.ContractPayments[idx].Start = dbItem.Start;
                        c.ContractPayments[idx].End = dbItem.End;
                        c.ContractPayments[idx].PaymentId = dbItem.PaymentId;

                        // update navigation property for UI by loading the updated ContractPayment including its Payment
                        var loadedCp = await db.ContractPayments.Include(x => x.Payment).FirstOrDefaultAsync(x => x.Id == id);
                        if (loadedCp != null)
                        {
                            c.ContractPayments[idx].Payment = loadedCp.Payment;
                        }
                    }
                }
                message = "Zuweisung gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            CancelEditContractPayment(id);
        }
    }
}
