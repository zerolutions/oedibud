@using Blazorise
@using oedibud.Data
@using oedibud.Models
@using oedibud.Services
@using Microsoft.EntityFrameworkCore
@using System.Linq
@inject BudgetDbContext Db
@inject TvLSalaryService TvL
@inject oedibud.Services.DataChangeNotifier Notifier

@code {
    private int Months = 12;
    private DateTime StartMonth = new DateTime(DateTime.Today.Year, 1, 1);

    public async Task NextMonth(int m)
    {
        StartMonth = StartMonth.AddMonths(m);
        await OnInitializedAsync();
    }

    private List<DateTime> Columns = new();

    private class RowItem
    {
        public enum RowType { Employee, Contract, ContractPayment }
        public RowType Type { get; set; }
        public int EmployeeId { get; set; }
        public int? ContractId { get; set; }
        public string Label { get; set; } = "";
        public string Title { get; set; } = "";
        public decimal[] Values { get; set; } = Array.Empty<decimal>();
    }

    private List<RowItem> Rows = new();
    private HashSet<int> Expanded = new();
    private decimal[] Totals = Array.Empty<decimal>();
    private Dictionary<int, Dictionary<int, decimal[]>>? _perContractPaymentAlloc = null;

    private Action? _onChangeHandler;

    protected override async Task OnInitializedAsync()
    {

        Notifier.OnChange -= _onChangeHandler;
        _onChangeHandler = () => _ = InvokeAsync(LoadDataAsync);
        Notifier.OnChange += _onChangeHandler;
        Columns.Clear();
        for (int i = 0; i < Months; i++)
            Columns.Add(StartMonth.AddMonths(i));

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        // load data
        var employees = await Db.Employees.ToListAsync();
        var contracts = await Db.Contracts
            .Include(c => c.ContractPayments)
                .ThenInclude(cp => cp.Payment)
                    .ThenInclude(p => p.Project)
            .ToListAsync();

        // build rows
        Rows.Clear();

        foreach (var emp in employees.OrderBy(e => e.Name))
        {
            var empRow = new RowItem
            {
                Type = RowItem.RowType.Employee,
                EmployeeId = emp.Id,
                Label = emp.Name,
                Values = new decimal[Months]
            };

            // find contracts for employee that overlap the period
            var empContracts = contracts.Where(c => c.EmployeeId == emp.Id && c.End >= Columns.First() && c.Start <= Columns.Last()).ToList();

            // compute per month contract cost and payments
            var contractMonthValues = new Dictionary<int, decimal[]>();
            _perContractPaymentAlloc ??= new Dictionary<int, Dictionary<int, decimal[]>>();
            var empMonthValues = new Dictionary<int, decimal[]>();

            foreach (var c in empContracts)
            {
                // positive monthly cost per month
                var monthlyCost = new decimal[Months];
                for (int m = 0; m < Months; m++)
                {
                    var month = Columns[m];
                    if (month < new DateTime(c.Start.Year, c.Start.Month, 1) || month > new DateTime(c.End.Year, c.End.Month, 1))
                        continue;

                    int level = emp.GetLevelAt(month);
                    var sal = TvL.GetSalary(emp.Group, level);
                    monthlyCost[m] = sal * (decimal)c.Fte;
                }

                var paymentsAssigned = new decimal[Months];
                var perPaymentAlloc = new Dictionary<int, decimal[]>();

                // allocate each contract payment greedily starting at cp.Start (or payment date)
                foreach (var cp in c.ContractPayments)
                {
                    var p = cp.Payment;
                    if (p == null) continue;

                    var alloc = new decimal[Months];

                    var rawStart = cp.Start ?? p.Start;
                    var start = rawStart < p.Start ? p.Start : rawStart;
                    var end = cp.End ?? c.End;

                    var startMonth = new DateTime(start.Year, start.Month, 1);
                    var endMonth = new DateTime(end.Year, end.Month, 1);

                    if (startMonth > endMonth)
                    {
                        perPaymentAlloc[cp.Id] = alloc;
                        continue;
                    }

                    var remaining = (p.Amount * cp.SharePercent) / 100m;

                    for (int m = 0; m < Months && remaining > 0; m++)
                    {
                        var month = Columns[m];
                        var monthStart = new DateTime(month.Year, month.Month, 1);
                        if (monthStart < startMonth || monthStart > endMonth) continue;
                        if (monthStart < new DateTime(p.Start.Year, p.Start.Month, 1) || ) continue;

                        var need = monthlyCost[m] - paymentsAssigned[m];
                        if (need <= 0) continue;

                        var take = Math.Min(need, remaining);
                        paymentsAssigned[m] += take;
                        alloc[m] += take;
                        remaining -= take;
                    }

                    perPaymentAlloc[cp.Id] = alloc;
                }

                // contract row = negative costs + assigned payments
                var arr = new decimal[Months];
                var arr2 = new decimal[Months];
                for (int m = 0; m < Months; m++)
                {
                    arr[m] = -monthlyCost[m] * emp.BruttoFactor; //+ paymentsAssigned[m];
                    arr2[m] = arr[m] + paymentsAssigned[m];
                }

                contractMonthValues[c.Id] = arr;
                empMonthValues[c.Id] = arr2;
                _perContractPaymentAlloc[c.Id] = perPaymentAlloc;
            }

            // fill employee totals as saldiert (netto): sum of contract rows (which already contain negative costs + assigned payments)
            for (int m = 0; m < Months; m++)
            {
                empRow.Values[m] = empMonthValues.Values.Sum(a => a[m]);
            }

            Rows.Add(empRow);

            // add contract rows and their payment rows as children (initially collapsed)
            foreach (var c in empContracts)
            {
                var crow = new RowItem
                {
                    Type = RowItem.RowType.Contract,
                    EmployeeId = emp.Id,
                    ContractId = c.Id,
                    Label = $"{((emp.Name + " | ") ?? "")}(V-{c.Id}) {c.Start:MM.yyyy} - {c.End:MM.yyyy}",
                    Title = $"ID {c.Id}",
                    Values = contractMonthValues[c.Id]
                };

                Rows.Add(crow);

                // add payment rows (show per-contract allocations computed earlier)
                foreach (var cp in c.ContractPayments)
                {
                    var p = cp.Payment;
                    if (p == null) continue;

                    decimal[] allocValues = new decimal[Months];
                    if (_perContractPaymentAlloc != null && _perContractPaymentAlloc.TryGetValue(c.Id, out var dict) && dict.TryGetValue(cp.Id, out var cpAlloc))
                        allocValues = cpAlloc;

                    Rows.Add(new RowItem
                    {
                        Type = RowItem.RowType.ContractPayment,
                        EmployeeId = emp.Id,
                        ContractId = c.Id,
                        Label = $"{((p.Project?.Title + " | ") ?? "")}(PM-{p.Id}) {cp.Payment?.Amount:C0} á {cp.SharePercent}%",
                        Title = $"Projektmittel: {p.Start:MM.yyyy} - {p.End:MM.yyyy}, Zuweisung: {p.Start:MM.yyyy} - {p.End:MM.yyyy}", //ToDo Zuweisungsdatum
                        Values = allocValues
                    });
                }
            }
        }

        // compute grand totals (sum of employee rows)
        Totals = new decimal[Months];
        foreach (var er in Rows.Where(r => r.Type == RowItem.RowType.Employee))
        {
            for (int m = 0; m < Months; m++)
                Totals[m] += er.Values[m];
        }
    }

    private void Toggle(int empId)
    {
        if (Expanded.Contains(empId)) Expanded.Remove(empId);
        else Expanded.Add(empId);
    }
}

@implements IDisposable

@code {
    void IDisposable.Dispose()
    {
        if (_onChangeHandler != null)
            Notifier.OnChange -= _onChangeHandler;
    }
}
<h3 class="text-primary-emphasis">Prognose</h3>
<hr />
<div style="display:flex; justify-content:center">
    <button type="button" class="btn btn-sm btn-light" title="12 Monate zurück" @onclick="@(e => NextMonth(-12))">⬅️⬅️</button>
    <button type="button" class="btn btn-sm btn-light ms-2" title="3 Monate zurück" @onclick="@(e => NextMonth(-3))">⬅️</button>
    <h4 class="m-2">@StartMonth.ToShortDateString() - @StartMonth.AddMonths(@Months).AddDays(-1).ToShortDateString()</h4>
    <button type="button" class="btn btn-sm btn-light me-2" title="3 Monate vorwärts" @onclick="@(e => NextMonth(3))">➡️</button>
    <button type="button" class="btn btn-sm btn-light" title="12 Monate vorwärts" @onclick="@(e => NextMonth(12))">➡️➡️</button>
</div>

<table class="table table-borderless mt-3 text-end">
    <thead>
        <tr>
            <th />
            <th>Person / Vertrag / Projektmittel</th>
            @foreach (var col in Columns)
            {
                <th>@col.ToString("MM/yyyy")</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Rows)
        {
            if (row.Type == RowItem.RowType.Employee)
            {
                <tr class="table-primary fw-bold">
                    <td>
                        <button class="btn btn pb-0 pt-0" @onclick="() => Toggle(row.EmployeeId)">
                            @(Expanded.Contains(row.EmployeeId) ? "-" : "+")
                        </button>
                    </td>
                    <td title="@row.Title">
                        @row.Label
                    </td>
                    @for (int i = 0; i < row.Values.Length; i++)
                    {
                        <td>@row.Values[i].ToString("C0")</td>
                    }
                </tr>
            }
            else if (row.Type == RowItem.RowType.Contract)
            {
                if (!Expanded.Contains(row.EmployeeId)) { continue; }
                <tr class="table-secondary">
                    <td class="table-primary" />
                    <td title="@row.Title" style="padding-left:10px">@row.Label</td>
                    @for (int i = 0; i < row.Values.Length; i++)
                    {
                        <td>@row.Values[i].ToString("C0")</td>
                    }
                </tr>
            }
            else if (row.Type == RowItem.RowType.ContractPayment)
            {
                if (!Expanded.Contains(row.EmployeeId)) { continue; }
                <tr class="table-success">
                    <td class="table-primary" />
                    <td title="@row.Title" style="padding-left:20px">@row.Label</td>
                    @for (int i = 0; i < row.Values.Length; i++)
                    {
                        <td>@row.Values[i].ToString("C0")</td>
                    }
                </tr>
            }
        }
    </tbody>
    <tfoot>
        <tr class="table-dark fw-bold">
            <td />
            <td>Gesamt</td>
            @for (int i = 0; i < Totals.Length; i++)
            {
                <td>@Totals[i].ToString("C0")</td>
            }
        </tr>
    </tfoot>
</table>

<table class="table table-borderless mt-5 w-25">
    <thead>
        <tr>
            <th>Legende</th>
        </tr>
    </thead>
    <tbody>
        <tr class="table-primary">
            <td>Mitarbeiter (M)</td>
        </tr>
        <tr class="table-secondary">
            <td>Vertrag (V)</td>
        </tr>
        <tr class="table-success">
            <td>Projekt / Projektmittel (PM)</td>
        </tr>
    </tbody>
</table>