@using System.Diagnostics
@using oedibud.Services
@inject ForecastEngine Engine
@inject oedibud.Services.DataChangeNotifier Notifier

@implements IDisposable

@code {
    private int Months = 12;
    private DateTime StartMonth = new(DateTime.Today.Year, 1, 1);

    private ForecastEngine.ForecastResult? Result;

    private HashSet<int> ExpandedEmployees = new();
    private HashSet<int> ExpandedProjects = new();

    private Action? _onChangeHandler;

    protected override async Task OnInitializedAsync()
    {
        Notifier.OnChange -= _onChangeHandler;
        _onChangeHandler = () => _ = InvokeAsync(LoadDataAsync);
        Notifier.OnChange += _onChangeHandler;

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        Result = await Engine.BuildAsync(StartMonth, Months);

        // wie vorher: standardmäßig expanden (optional; entspricht deinem "Expanded.Add(id)" Verhalten)
        ExpandedEmployees = Result.Nodes
            .Where(n => n.RootKind == ForecastEngine.RootKind.Employee && n.Level == 0 && n.EmployeeId.HasValue)
            .Select(n => n.RootId)
            .ToHashSet();

        ExpandedProjects = Result.Nodes
            .Where(n => n.RootKind == ForecastEngine.RootKind.Project && n.Level == 0 && n.ProjectId.HasValue)
            .Select(n => n.RootId)
            .ToHashSet();
    }

    public async Task NextMonth(int m)
    {
        Debug.WriteLine("NextMonthClicked");
        StartMonth = StartMonth.AddMonths(m);
        await LoadDataAsync();
    }

    private void ToggleEmployee(int empId)
    {
        if (ExpandedEmployees.Contains(empId)) ExpandedEmployees.Remove(empId);
        else ExpandedEmployees.Add(empId);
    }

    private void ToggleProject(int projectId)
    {
        if (ExpandedProjects.Contains(projectId)) ExpandedProjects.Remove(projectId);
        else ExpandedProjects.Add(projectId);
    }

    void IDisposable.Dispose()
    {
        if (_onChangeHandler != null)
            Notifier.OnChange -= _onChangeHandler;
    }
    private string FormatCurrencyShort(decimal value)
    {
        var abs = Math.Abs(value);

        if (abs >= 1_000)
            return $"{value / 1_000:0.}k €";

        return value.ToString("C0");
    }
}

<h3 class="text-primary-emphasis">Prognose</h3>
<hr />

<div style="display:flex; justify-content:center">
    <button type="button" class="btn btn-sm btn-light" title="12 Monate zurück" @onclick="@(e => NextMonth(-12))">⬅️⬅️</button>
    <button type="button" class="btn btn-sm btn-light ms-2" title="1 Monate zurück" @onclick="@(e => NextMonth(-1))">⬅️</button>
    <h4 class="m-2">@StartMonth.ToString("MMM yy") - @StartMonth.AddMonths(@Months).AddDays(-1).ToString("MMM yy")</h4>
    <button type="button" class="btn btn-sm btn-light me-2" title="1 Monate vorwärts" @onclick="@(e => NextMonth(1))">➡️</button>
    <button type="button" class="btn btn-sm btn-light" title="12 Monate vorwärts" @onclick="@(e => NextMonth(12))">➡️➡️</button>
</div>

@if (Result is null)
{
    <p>Lade…</p>
}
else
{
    <h4 class="mt-5 text-center">Projektbudgets (kummuliert)</h4>

    @* -------------------------
       Tabelle 2: Projekt-Sicht
       ------------------------- *@
    <table class="table table-sm table-borderless mt-3 text-end table-hover">
        <thead>
            <tr>
                <th />
                <th></th>
                @foreach (var col in Result.Columns)
                {
                    <th>@col.ToString("MMM yy")</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Result.Nodes.Where(n => n.RootKind == ForecastEngine.RootKind.Project))
            {
                if (row.Level > 0 && !ExpandedProjects.Contains(row.RootId)) { continue; }

                if (row.Level == 0)
                {
                    <tr class="table-danger fw-bold">
                        <td>
                            <button class="btn btn pb-0 pt-0" @onclick="() => ToggleProject(row.RootId)">
                                @(ExpandedProjects.Contains(row.RootId) ? "-" : "+")
                            </button>
                        </td>
                        <td title="@row.Title">@((MarkupString)row.Label)</td>
                        @for (int i = 0; i < row.Values.Length; i++)
                        {
                            <td class="@(@row.Values[i] < 0 ? "text-danger" : "")">@FormatCurrencyShort(row.Values[i])</td>
                        }
                    </tr>
                }
                else if (row.Level == 1)
                {
                    <tr class="table-success">
                        <td class="table-danger" />
                        <td title="@row.Title" style="padding-left:10px">@((MarkupString)row.Label)</td>
                        @for (int i = 0; i < row.Values.Length; i++)
                        {
                            <td class="@(@row.Values[i] < 0 ? "text-danger" : "")">@FormatCurrencyShort(row.Values[i])</td>
                        }
                    </tr>
                }
                else
                {
                    <tr class="table-secondary">
                        <td class="table-danger" />
                        <td title="@row.Title" style="padding-left:20px">@((MarkupString)row.Label)</td>
                        @for (int i = 0; i < row.Values.Length; i++)
                        {
                            <td>@FormatCurrencyShort(row.Values[i])</td>
                        }
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr class="table-dark fw-bold">
                <td />
                <td>Gesamt</td>
                @for (int i = 0; i < Result.ProjectTotals.Length; i++)
                {
                    <td class="@(@Result.ProjectTotals[i] < 0 ? "text-danger" : "")">@FormatCurrencyShort(Result.ProjectTotals[i])</td>
                }
            </tr>
        </tfoot>
    </table>

    @* -------------------------
       Tabelle 1: Mitarbeiter-Sicht
       ------------------------- *@
    <h4 class="mt-5 text-center">Personalsaldo (nicht kummuliert)</h4>
    <table class="table table-sm table-borderless mt-3 text-end table-hover">
        <thead>
            <tr>
                <th />
                <th></th>
                @foreach (var col in Result.Columns)
                {
                    <th>@col.ToString("MMM yy")</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Result.Nodes.Where(n => n.RootKind == ForecastEngine.RootKind.Employee))
            {
                if (row.Level > 0 && !ExpandedEmployees.Contains(row.RootId)) { continue; }

                if (row.Level == 0)
                {
                    <tr class="table-primary fw-bold">
                        <td>
                            <button class="btn btn pb-0 pt-0" @onclick="() => ToggleEmployee(row.RootId)">
                                @(ExpandedEmployees.Contains(row.RootId) ? "-" : "+")
                            </button>
                        </td>
                        <td title="@row.Title">@((MarkupString)row.Label)</td>
                        @for (int i = 0; i < row.Values.Length; i++)
                        {
                            <td class="@(@row.Values[i] < 0 ? "text-danger" : "")">@FormatCurrencyShort(row.Values[i])</td>
                        }
                    </tr>
                }
                else if (row.Level == 1)
                {
                    <tr class="table-secondary">
                        <td class="table-primary" />
                        <td title="@row.Title" style="padding-left:10px">@((MarkupString)row.Label)</td>
                        @for (int i = 0; i < row.Values.Length; i++)
                        {
                            <td>@FormatCurrencyShort(row.Values[i])</td>
                        }
                    </tr>
                }
                else
                {
                    <tr class="table-success">
                        <td class="table-primary" />
                        <td title="@row.Title" style="padding-left:20px">@((MarkupString)row.Label)</td>
                        @for (int i = 0; i < row.Values.Length; i++)
                        {
                            <td>@FormatCurrencyShort(row.Values[i])</td>
                        }
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr class="table-dark fw-bold">
                <td />
                <td>Gesamt</td>
                @for (int i = 0; i < Result.EmployeeTotals.Length; i++)
                {
                    <td class="@(@Result.EmployeeTotals[i] < 0 ? "text-danger" : "")">@FormatCurrencyShort(Result.EmployeeTotals[i])</td>
                }
            </tr>
        </tfoot>
    </table>

    @* <table class="table table-borderless mt-5 w-25">
        <thead>
            <tr>
                <th>Legende</th>
            </tr>
        </thead>
        <tbody>
            <tr class="table-primary">
                <td class="fw-bold">Mitarbeiter | Gruppe</td>
            </tr>
            <tr class="table-secondary">
                <td>Vertragslaufzeit</td>
            </tr>
            <tr class="table-success">
                <td>Projekt | Anteil an Projektmittelsumme</td>
            </tr>
        </tbody>
    </table> *@
}
