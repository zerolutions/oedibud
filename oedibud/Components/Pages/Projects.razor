@page "/projects"

@using Microsoft.EntityFrameworkCore
@using oedibud.Models
@using oedibud.Data
@inject IDbContextFactory<BudgetDbContext> DbFactory

<h3>Projekte</h3>

<div class="mb-3">
    Titel:<input @bind="project.Title" class="form-control mb-1" />
    Projektstart:<input type="date" @bind="project.Start" class="form-control mb-1" />
    Projektende:<input type="date" @bind="project.End" class="form-control mb-1" />
    <button class="btn btn-primary" @onclick="AddProject">Hinzufügen</button>
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="mt-2 text-info">@message</div>
    }
</div>
<hr />

@if (projects.Count == 0)
{
    <p>Keine Projekte verfügbar.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titel</th>
                <th>Projektstart</th>
                <th>Projektende</th>
                <th>Gesamt</th>
                <th>Zahlungen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in projects)
            {
                <tr>
                    <td>@p.Id</td>
                    @if (editingProjectId == p.Id)
                    {
                        <td><input class="form-control" @bind="editProjectCopy.Title" /></td>
                        <td><input type="date" class="form-control" @bind="editProjectCopy.Start" /></td>
                        <td><input type="date" class="form-control" @bind="editProjectCopy.End" /></td>
                        <td>@p.TotalAmount.ToString("C")</td>
                        <td>
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveProject(editProjectCopy.Id)">Speichern</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => CancelEditProject()">Abbrechen</button>
                        </td>
                        <td></td>
                    }
                    else
                    {
                        <td>@p.Title</td>
                        <td>@p.Start.ToShortDateString()</td>
                        <td>@p.End.ToShortDateString()</td>
                        <td>@p.TotalAmount.ToString("C")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(p.Id)">
                                @(expanded.Contains(p.Id) ? "-" : "+")
                            </button>
                        </td>

                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditProject(p)">Bearbeiten</button>
                            <button type="button" class="btn btn-danger" @onclick="@(a => DeleteProjectAndPayments(@p))">Projekt löschen</button>
                        </td>
                    }
                </tr>
                @if (expanded.Contains(p.Id))
                {
                    <tr>
                        <td colspan="7" class="p-0">
                            <div class="p-3">
                                <h6>Personalmittel</h6>
                                @if (p.Payments.Count == 0)
                                {
                                    <div><em>Keine Personalmittel</em></div>
                                }
                                else
                                {
                                    <table class="table table-sm">
                                        <thead>
                                            <tr><th>Datum</th><th>Betrag</th><th>Gewidmet</th><th></th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var pay in p.Payments.OrderByDescending(x => x.Date))
                                            {
                                                <tr>
                                                    @if (editingPaymentIds.Contains(pay.Id))
                                                    {
                                                        <td><input type="date" class="form-control" @bind="editPaymentCopies[pay.Id].Date" /></td>
                                                        <td><input type="number" step="0.01" class="form-control" @bind="editPaymentCopies[pay.Id].Amount" /></td>
                                                        <td>
                                                            <select class="form-control" @bind="editPaymentCopies[pay.Id].DetecatedTo">
                                                                <option value="">-- keine Angabe --</option>
                                                                @foreach (var g in Enum.GetValues<EmployeeGroup>())
                                                                {
                                                                    <option value="@g">@g</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-success me-1" @onclick="() => SavePayment(pay.Id)">Speichern</button>
                                                            <button class="btn btn-sm btn-secondary" @onclick="() => CancelEditPayment(pay.Id)">Abbrechen</button>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>@pay.Date.ToShortDateString()</td>
                                                        <td>@pay.Amount.ToString("C")</td>
                                                        <td>@pay.DetecatedTo.ToString()</td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditPayment(pay)">Bearbeiten</button>
                                                            <button class="btn btn-sm btn-danger" @onclick="() => DeletePayment(p, pay)">Zahlung löschen</button>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }

                                <div class="border-top pt-2 mt-2">
                                    @* <h6>Add payment</h6> *@
                                    <div class="row g-2 align-items-end">
                                        <div class="col-auto">
                                            <label class="form-label">Datum</label>
                                            <input type="date" class="form-control" @bind="paymentInputs[p.Id].Date" />
                                        </div>
                                        <div class="col-auto">
                                            <label class="form-label">Betrag</label>
                                            <input type="number" step="0.01" class="form-control" @bind="paymentInputs[p.Id].Amount" />
                                        </div>
                                        <div class="col-auto">
                                            <label class="form-label>">Gewidmet</label>
                                            <select class="form-control" @bind="paymentInputs[p.Id].DetecatedTo">
                                                <option value="">-- keine Angabe --</option>
                                                @foreach (var g in Enum.GetValues<EmployeeGroup>())
                                                {
                                                    <option value="@g">@g</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-auto">
                                            <button class="btn btn-success" @onclick="() => AddPayment(p)">Hinzufügen</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private List<Project> projects = new();
    // private string newProjectTitle = "";

    private Project project = new()
    {
        Start = DateTime.Today,
        End = DateTime.Today.AddYears(3)
    };
    private string message = "";
    private HashSet<int> expanded = new();

    // simple per-project input model for new payment
    private class PaymentInput
    {
        public DateTime Date { get; set; }
        public decimal Amount { get; set; }
        public EmployeeGroup? DetecatedTo { get; set; }

        public PaymentInput() { }
        public PaymentInput(DateTime date, decimal amount, EmployeeGroup? dedicatedTo)
        {
            Date = date;
            Amount = amount;
            DetecatedTo = dedicatedTo;
        }
    }
    private Dictionary<int, PaymentInput> paymentInputs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        using var db = DbFactory.CreateDbContext();
        projects = await db.Projects
            .Include(p => p.Payments)
            .OrderByDescending(p => p.Start)
            .ToListAsync();

        // ensure paymentInputs entries exist
        paymentInputs = projects.ToDictionary(p => p.Id, p => new PaymentInput(DateTime.Today, 0m, null));
    }

    private void ToggleExpand(int projectId)
    {
        if (!expanded.Remove(projectId))
        {
            expanded.Add(projectId);
            if (!paymentInputs.ContainsKey(projectId))
                paymentInputs[projectId] = new PaymentInput(DateTime.Today, 0m, null);
        }
    }

    private async Task AddProject()
    {
        if (string.IsNullOrWhiteSpace(project.Title))
        {
            message = "Eingabe eines Titels ist notwendig.";
            return;
        }

        try
        {
            // var project = new Project { Title = newProjectTitle, Created = DateTime.UtcNow };

            using var db = DbFactory.CreateDbContext();
            db.Projects.Add(project);
            await db.SaveChangesAsync();

            // load payments navigation empty
            project.Payments = new List<Payment>();
            projects.Insert(0, project);
            paymentInputs[project.Id] = new PaymentInput(DateTime.Today, 0m, null);
            // newProjectTitle = "";
            message = $"Projekt '{project.Title}' hinzugefügt.";
            project = new()
            {
                Start = DateTime.Today,
                End = DateTime.Today.AddYears(3)
            };
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task AddPayment(Project project)
    {
        if (!paymentInputs.TryGetValue(project.Id, out var input))
            return;

        if (input.Amount == 0m)
        {
            message = "Betrag muss größer als 0 sein.";
            return;
        }

        var payment = new Payment
        {
            ProjectId = project.Id,
            Date = input.Date,
            Amount = input.Amount,
            DetecatedTo = input.DetecatedTo
        };

        try
        {
            using var db = DbFactory.CreateDbContext();
            db.Payments.Add(payment);
            await db.SaveChangesAsync();

            // update local model (ensure list exists)
            var target = projects.FirstOrDefault(p => p.Id == project.Id);
            if (target != null)
            {
                target.Payments.Add(payment);
            }

            // reset input
            paymentInputs[project.Id] = new PaymentInput(DateTime.Today, 0m, null);
            message = "Zahlung hinzugefügt.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteProjectAndPayments(Project project)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            // load payments to ensure cascade delete works
            var toDelete = await db.Projects.Include(p => p.Payments).FirstOrDefaultAsync(p => p.Id == project.Id);
            if (toDelete != null)
            {
                db.Projects.Remove(toDelete);
                await db.SaveChangesAsync();
                projects.RemoveAll(p => p.Id == project.Id);
                paymentInputs.Remove(project.Id);
                message = "Projekt gelöscht.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeletePayment(Project project, Payment payment)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            db.Payments.Remove(payment);
            await db.SaveChangesAsync();

            var target = projects.FirstOrDefault(p => p.Id == project.Id);
            if (target != null)
            {
                target.Payments.RemoveAll(p => p.Id == payment.Id);
            }
            message = "Zahlung gelöscht.";
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    // --- Inline edit support for projects/payments ---
    private int? editingProjectId = null;
    private Project editProjectCopy = new Project();

    private HashSet<int> editingPaymentIds = new();
    private Dictionary<int, Payment> editPaymentCopies = new();

    private void EditProject(Project p)
    {
        editingProjectId = p.Id;
        editProjectCopy = new Project
        {
            Id = p.Id,
            Title = p.Title,
            Start = p.Start,
            End = p.End
        };
    }

    private void CancelEditProject()
    {
        editingProjectId = null;
        editProjectCopy = new Project();
    }

    private async Task SaveProject(int id)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.Projects.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.Title = editProjectCopy.Title;
                dbItem.Start = editProjectCopy.Start;
                dbItem.End = editProjectCopy.End;
                await db.SaveChangesAsync();

                var idx = projects.FindIndex(x => x.Id == id);
                if (idx >= 0)
                {
                    projects[idx].Title = dbItem.Title;
                    projects[idx].Start = dbItem.Start;
                    projects[idx].End = dbItem.End;
                }
                message = "Projekt gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            CancelEditProject();
        }
    }

    private void EditPayment(Payment p)
    {
        editingPaymentIds.Add(p.Id);
        editPaymentCopies[p.Id] = new Payment
        {
            Id = p.Id,
            Date = p.Date,
            Amount = p.Amount,
            DetecatedTo = p.DetecatedTo,
            ProjectId = p.ProjectId
        };
    }

    private void CancelEditPayment(int id)
    {
        editingPaymentIds.Remove(id);
        editPaymentCopies.Remove(id);
    }

    private async Task SavePayment(int id)
    {
        if (!editPaymentCopies.TryGetValue(id, out var copy)) return;
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.Payments.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.Date = copy.Date;
                dbItem.Amount = copy.Amount;
                dbItem.DetecatedTo = copy.DetecatedTo;
                await db.SaveChangesAsync();

                foreach (var proj in projects)
                {
                    var idx = proj.Payments?.FindIndex(x => x.Id == id) ?? -1;
                    if (idx >= 0)
                    {
                        proj.Payments[idx].Date = dbItem.Date;
                        proj.Payments[idx].Amount = dbItem.Amount;
                        proj.Payments[idx].DetecatedTo = dbItem.DetecatedTo;
                    }
                }
                message = "Zahlung gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            CancelEditPayment(id);
        }
    }
}
