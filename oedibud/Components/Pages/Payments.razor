@page "/payments"

@using Microsoft.EntityFrameworkCore
@using oedibud.Models
@using oedibud.Data
@inject IDbContextFactory<BudgetDbContext> DbFactory
@inject oedibud.Services.DataChangeNotifier Notifier

<PageTitle>Projektmittel</PageTitle>

<h3 class="text-primary-emphasis">Projektmittel</h3>
<hr />
<div class="mb-3">
    <label>Projekt</label>
    <select class="form-control mb-2" value="@newPayment.ProjectId" @onchange="NewPaymentProjectChanged">
        <option value="0">-- auswählen --</option>
        @foreach (var pr in projects)
        {
            <option value="@pr.Id">@pr.Title</option>
        }
    </select>
    <label>Von</label>
    <input type="date" class="form-control mb-2" @bind="newPayment.Start" />
    <label>Bis</label>
    <input type="date" class="form-control mb-2" @bind="newPayment.End" />
    <label>Betrag</label>
    <input type="number" step="1" class="form-control mb-2" @bind="newPayment.Amount" />
    <label>Gewidmet</label>
    <select class="form-control mb-2" @bind="newPayment.DetecatedTo">
        <option value="">-- keine Angabe --</option>
        @foreach (var g in Enum.GetValues<EmployeeGroup>())
        {
            <option value="@g">@g</option>
        }
    </select>
    <button class="btn btn-primary mt-2" @onclick="AddNewPayment">Projektmittel hinzufügen</button>
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="mt-2 text-info">@message</div>
    }
</div>

@if (payments.Count == 0)
{
    <p>Keine Projektmittel vorhanden.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>ID</th><th>Projekt</th><th>Von</th><th>Bis</th><th>Betrag</th><th>Gewidmet</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var p in payments)
            {
                if (editingPaymentId == p.Id)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>
                            <select class="form-control" @bind="editPaymentCopy.ProjectId">
                                @foreach (var pr in projects)
                                {
                                    <option value="@pr.Id">@pr.Title</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input type="date" class="form-control mb-1" @bind="editPaymentCopy.Start" />
                        </td>
                        <td>
                            <input type="date" class="form-control" @bind="editPaymentCopy.End" />
                        </td>
                        <td><input type="number" step="1" class="form-control" @bind="editPaymentCopy.Amount" /></td>
                        <td>
                            <select class="form-control" @bind="editPaymentCopy.DetecatedTo">
                                <option value="">-- keine Angabe --</option>
                                @foreach (var g in Enum.GetValues<EmployeeGroup>())
                                {
                                    <option value="@g">@g</option>
                                }
                            </select>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-success me-2" @onclick="() => SavePaymentEdit(p.Id)">Speichern</button>
                            <button class="btn btn-sm btn-secondary me-2" @onclick="() => CancelEditPayment()">Abbrechen</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(p.Id)">@(expanded.Contains(p.Id) ? "Verstecken" : "Arbeitsverträge zuweisen")</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@(p.Project?.Title ?? "-")</td>
                        <td>@p.Start.ToShortDateString()</td>
                        <td>@p.End.ToShortDateString()</td>
                        <td>@p.Amount.ToString("C")</td>
                        <td>@(p.DetecatedTo?.ToString() ?? "-")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditPaymentRow(p)">Bearbeiten</button>
                            <button class="btn btn-sm btn-danger me-2" @onclick="() => DeletePayment(p)">Löschen</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(p.Id)">@(expanded.Contains(p.Id) ? "Verstecken" : "Arbeitsverträge zuweisen")</button>
                        </td>
                    </tr>
                }

                if (expanded.Contains(p.Id))
                {
                    <tr>
                        <td colspan="6" class="p-0 bg-dark-subtle">
                            <div class="p-3">
                                @if (p.ContractPayments == null || p.ContractPayments.Count == 0)
                                {
                                    <div><em>Keine Arbeitsverträge zugewiesen</em></div>
                                }
                                <table class="table-sm">
                                    <thead><tr><th>Mitarbeiter</th><th>AV-ID</th><th>Lohnanteil</th><th>Von</th><th>Bis</th><th></th></tr></thead>
                                    <tbody>
                                        @foreach (var cp in p.ContractPayments.OrderByDescending(x => x.SharePercent))
                                        {
                                            <tr>
                                                @if (editingContractAssignIds.Contains(cp.Id))
                                                {
                                                    @* <td>@(cp.Contract?.Employee?.Name ?? "-")</td>
                                                    <td>@(cp.Contract?.Id.ToString() ?? "-")</td> *@
                                                    
                                                    <td colspan="2">
                                                        <select class="form-control" @bind="editContractAssignCopies[cp.Id].ContractId">
                                                            <option value="0">-- auswählen --</option>
                                                            @* <option value="@editContractAssignCopies[cp.Id].PaymentId">@($"{payments.FirstOrDefault(p => p.Id == cp.PaymentId)?.Project?.Title ?? "Unbekanntes Projekt"} | PM-{cp.Payment?.Id} | {cp.Payment?.Start.ToShortDateString()} - {cp.Payment?.End.ToShortDateString()} | {cp.Payment?.Amount.ToString("C")} | {(cp.Payment?.DetecatedTo?.ToString() ?? "-")}")</option> *@
                                                            <option value="@editContractAssignCopies[cp.Id].ContractId">@($"{cp.Contract?.Employee?.Name ?? "-"} | AV-{cp.ContractId} ({cp.Contract?.Start.ToShortDateString()} - {cp.Contract?.End.ToShortDateString()})")</option>
                                                            @foreach (var c in AvailableContractsForPayment(p))
                                                            {
                                                                <option value="@c.Id">@($"{c.Employee?.Name ?? "-"} | AV-{c.Id} ({c.Start.ToShortDateString()} - {c.End.ToShortDateString()})")</option>
                                                            }
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <div class="input-group">
                                                            <input type="number"
                                                                   class="form-control"
                                                                   step="1"
                                                                   min="0"
                                                                   max="100"
                                                                   @bind="editContractAssignCopies[cp.Id].SharePercent" />
                                                            <span class="input-group-text">%</span>
                                                        </div>
                                                    </td>
                                                    <td><input type="date" class="form-control" @bind="editContractAssignCopies[cp.Id].Start" /></td>
                                                    <td><input type="date" class="form-control" @bind="editContractAssignCopies[cp.Id].End" /></td>
                                                    <td>
                                                        <button class="btn btn-sm btn-success me-1" @onclick="() => SaveContractAssignmentEdit(cp.Id)">Speichern</button>
                                                        <button class="btn btn-sm btn-secondary" @onclick="() => CancelEditContractAssignment(cp.Id)">Abbrechen</button>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td>@(cp.Contract?.Employee?.Name ?? "-")</td>
                                                    <td>@(cp.Contract?.Id.ToString() ?? "-")</td>
                                                    <td>@cp.SharePercent%</td>
                                                    <td>@(cp.Start?.ToShortDateString() ?? "-")</td>
                                                    <td>@(cp.End?.ToShortDateString() ?? "-")</td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditContractAssignment(cp)">Bearbeiten</button>
                                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteContractAssignment(cp.Id, p.Id)">Entfernen</button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                        <tr>
                                            <td colspan="2">
                                                <select class="form-control" @bind="contractInputs[p.Id].ContractId">
                                                    <option value="0">-- auswählen --</option>
                                                    @foreach (var c in AvailableContractsForPayment(p))
                                                    {
                                                        <option value="@c.Id">@($"{c.Employee?.Name ?? "-"} | AV-{c.Id} ({c.Start.ToShortDateString()} - {c.End.ToShortDateString()})")</option>
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <div class="input-group">
                                                    <input type="number"
                                                           class="form-control"
                                                           step="1"
                                                           min="0"
                                                           max="100"
                                                           @bind="contractInputs[p.Id].SharePercent" />
                                                    <span class="input-group-text">%</span>
                                                </div>
                                            </td>
                                            <td>
                                                <input type="date" class="form-control" @bind="contractInputs[p.Id].Start" />
                                            </td>
                                            <td>
                                                <input type="date" class="form-control" @bind="contractInputs[p.Id].End" />
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-success" @onclick="() => AddContractAssignment(p)">Zuweisen</button>
                                            </td>

                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private List<Payment> payments = new();
    private List<Contract> contracts = new();
    private List<Project> projects = new();
    private HashSet<int> expanded = new();
    private string message = string.Empty;

    // new payment creation model for top form
    private class NewPaymentInputModel
    {
        public int ProjectId { get; set; }
        public DateTime Start { get; set; } = DateTime.Today;
        public DateTime End { get; set; } = DateTime.Today;
        public decimal Amount { get; set; }
        public EmployeeGroup? DetecatedTo { get; set; }
    }

    private NewPaymentInputModel newPayment = new NewPaymentInputModel();

    // inline edit for payments
    private int? editingPaymentId = null;
    private Payment editPaymentCopy = new Payment();

    private class ContractAssignInput
    {
        public int ContractId { get; set; }
        public int SharePercent { get; set; } = 100;
        public DateTime? Start { get; set; }
        public DateTime? End { get; set; }
    }

    private Dictionary<int, ContractAssignInput> contractInputs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = DbFactory.CreateDbContext();
        // load contracts with employee navigation
        contracts = await db.Contracts.Include(c => c.Employee).OrderByDescending(c => c.Start).ToListAsync();

        // load projects for new-payment select
        projects = await db.Projects.OrderByDescending(p => p.Start).ToListAsync();

        // load payments including existing contract assignments and contract->employee
        payments = await db.Payments
            .Include(p => p.Project)
            .Include(p => p.ContractPayments)
                .ThenInclude(cp => cp.Contract)
                    .ThenInclude(c => c.Employee)
            .OrderByDescending(p => p.Start)
            .ToListAsync();

        contractInputs = payments.ToDictionary(p => p.Id, p => new ContractAssignInput());

        // ensure newPayment project default is set if possible
        if (projects.Count > 0 && newPayment.ProjectId == 0)
        {
            newPayment.ProjectId = projects.First().Id;
            // prefill start/end from first project
            newPayment.Start = projects.First().Start;
            newPayment.End = projects.First().End;
        }
    }

    private void NewPaymentProjectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e?.Value?.ToString(), out var id))
        {
            newPayment.ProjectId = id;
            var pr = projects.FirstOrDefault(p => p.Id == id);
            if (pr != null)
            {
                newPayment.Start = pr.Start;
                newPayment.End = pr.End;
            }
        }
    }

    private IEnumerable<Contract> AvailableContractsForPayment(Payment p)
    {
        var paymentGroup = p.DetecatedTo;
        var assignedIds = p.ContractPayments?.Select(x => x.ContractId).ToHashSet() ?? new HashSet<int>();
        return contracts.Where(c => !assignedIds.Contains(c.Id) && (paymentGroup == null || (c.Employee != null && c.Employee.Group == paymentGroup)));
    }

    private void ToggleExpand(int id)
    {
        if (!expanded.Remove(id))
        {
            expanded.Add(id);
            if (!contractInputs.ContainsKey(id)) contractInputs[id] = new ContractAssignInput();
        }
    }

    private async Task AddContractAssignment(Payment p)
    {
        if (!contractInputs.TryGetValue(p.Id, out var input)) return;
        if (input.ContractId == 0)
        {
            message = "Bitte einen Vertrag auswählen.";
            return;
        }
        if (input.SharePercent < 0 || input.SharePercent > 100)
        {
            message = "Lohnanteil muss zwischen 0 und 100 liegen.";
            return;
        }

        try
        {
            using var db = DbFactory.CreateDbContext();
            var cp = new ContractPayment
            {
                PaymentId = p.Id,
                ContractId = input.ContractId,
                SharePercent = input.SharePercent,
                Start = input.Start,
                End = input.End
            };
            db.Add(cp);
            await db.SaveChangesAsync();

            var loaded = await db.ContractPayments.Include(x => x.Contract).ThenInclude(c => c.Employee).FirstOrDefaultAsync(x => x.Id == cp.Id);
            if (loaded != null)
            {
                var target = payments.FirstOrDefault(x => x.Id == p.Id);
                if (target != null) target.ContractPayments.Add(loaded);
            }

            message = "Vertrag zugewiesen.";
            contractInputs[p.Id] = new ContractAssignInput();
            Notifier.Notify();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteContractAssignment(int contractPaymentId, int paymentId)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.ContractPayments.FindAsync(contractPaymentId);
            if (item != null)
            {
                db.ContractPayments.Remove(item);
                await db.SaveChangesAsync();
                var target = payments.FirstOrDefault(x => x.Id == paymentId);
                if (target != null) target.ContractPayments.RemoveAll(x => x.Id == contractPaymentId);
                message = "Zuweisung entfernt.";
                Notifier.Notify();
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    // --- Payment create / edit / delete ---
    private async Task AddNewPayment()
    {
        if (newPayment.ProjectId == 0)
        {
            message = "Bitte ein Projekt auswählen.";
            return;
        }
        if (newPayment.Amount == 0m)
        {
            message = "Betrag muss größer als 0 sein.";
            return;
        }

        try
        {
            using var db = DbFactory.CreateDbContext();
            var toSave = new Payment
            {
                ProjectId = newPayment.ProjectId,
                Start = newPayment.Start,
                End = newPayment.End,
                Amount = newPayment.Amount,
                DetecatedTo = newPayment.DetecatedTo
            };
            db.Payments.Add(toSave);
            await db.SaveChangesAsync();

            var saved = await db.Payments.Include(p => p.Project).FirstOrDefaultAsync(p => p.Id == toSave.Id);
            if (saved != null)
            {
                saved.ContractPayments = new List<ContractPayment>();
                payments.Insert(0, saved);
                contractInputs[saved.Id] = new ContractAssignInput();
            }

            // reset, keep project selection
            newPayment = new NewPaymentInputModel { ProjectId = newPayment.ProjectId, Start = DateTime.Today, End = DateTime.Today };
            message = "Projektmittel hinzugefügt.";
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private void EditPaymentRow(Payment p)
    {
        editingPaymentId = p.Id;
        editPaymentCopy = new Payment
        {
            Id = p.Id,
            ProjectId = p.ProjectId,
            Start = p.Start,
            End = p.End,
            Amount = p.Amount,
            DetecatedTo = p.DetecatedTo,
            Project = p.Project
        };
    }

    private void CancelEditPayment()
    {
        editingPaymentId = null;
        editPaymentCopy = new Payment();
    }

    private async Task SavePaymentEdit(int id)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.Payments.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.ProjectId = editPaymentCopy.ProjectId;
                dbItem.Start = editPaymentCopy.Start;
                dbItem.End = editPaymentCopy.End;
                dbItem.Amount = editPaymentCopy.Amount;
                dbItem.DetecatedTo = editPaymentCopy.DetecatedTo;
                await db.SaveChangesAsync();

                var idx = payments.FindIndex(x => x.Id == id);
                if (idx >= 0)
                {
                    payments[idx].Project = projects.FirstOrDefault(pr => pr.Id == editPaymentCopy.ProjectId) ?? payments[idx].Project;
                    payments[idx].ProjectId = editPaymentCopy.ProjectId;
                    payments[idx].Start = editPaymentCopy.Start;
                    payments[idx].End = editPaymentCopy.End;
                    payments[idx].Amount = editPaymentCopy.Amount;
                    payments[idx].DetecatedTo = editPaymentCopy.DetecatedTo;
                }
                message = "Projektmittel gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            CancelEditPayment();
        }
    }

    private async Task DeletePayment(Payment p)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.Payments.FindAsync(p.Id);
            if (item != null)
            {
                db.Payments.Remove(item);
                await db.SaveChangesAsync();
                payments.RemoveAll(x => x.Id == p.Id);
                contractInputs.Remove(p.Id);
                message = "Projektmittel gelöscht.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    // --- Inline edit support for contract assignments ---
    private HashSet<int> editingContractAssignIds = new();
    private Dictionary<int, ContractPayment> editContractAssignCopies = new();

    private void EditContractAssignment(ContractPayment cp)
    {
        editingContractAssignIds.Add(cp.Id);
        editContractAssignCopies[cp.Id] = new ContractPayment
        {
            Id = cp.Id,
            ContractId = cp.ContractId,
            PaymentId = cp.PaymentId,
            SharePercent = cp.SharePercent,
            Start = cp.Start,
            End = cp.End
        };
    }

    private void CancelEditContractAssignment(int id)
    {
        editingContractAssignIds.Remove(id);
        editContractAssignCopies.Remove(id);
    }

    private async Task SaveContractAssignmentEdit(int id)
    {
        if (!editContractAssignCopies.TryGetValue(id, out var copy)) return;
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.ContractPayments.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.SharePercent = copy.SharePercent;
                dbItem.Start = copy.Start;
                dbItem.End = copy.End;
                dbItem.ContractId = copy.ContractId;
                await db.SaveChangesAsync();

                var parent = payments.FirstOrDefault(p => p.ContractPayments.Any(x => x.Id == id));
                if (parent != null)
                {
                    var idx = parent.ContractPayments.FindIndex(x => x.Id == id);
                    if (idx >= 0)
                    {
                        parent.ContractPayments[idx].SharePercent = dbItem.SharePercent;
                        parent.ContractPayments[idx].Start = dbItem.Start;
                        parent.ContractPayments[idx].End = dbItem.End;
                        parent.ContractPayments[idx].ContractId = dbItem.ContractId;

                        var loadedCp = await db.ContractPayments
                            .Include(x => x.Contract)
                                .ThenInclude(c => c.Employee)
                            .FirstOrDefaultAsync(x => x.Id == id);

                        if (loadedCp != null)
                        {
                            parent.ContractPayments[idx].Contract = loadedCp.Contract;
                        }
                    }
                }
                message = "Zuweisung gespeichert.";
                Notifier.Notify();
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            CancelEditContractAssignment(id);
        }
    }
}
