@page "/employees"

@using Blazorise
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using System.Linq
@using oedibud.Models
@using oedibud.Data
@inject IDbContextFactory<BudgetDbContext> DbFactory

<PageTitle>Mitarbeiter</PageTitle>

<h3 class="text-primary-emphasis">Mitarbeiter</h3>
<hr/>

<div class="mb-3">
    Name <input @bind="employee.Name" class="form-control mb-2" />
    Eingestellt am<input type="date" @bind="employee.HireDate" class="form-control mb-2" />
    Gruppe
    <select @bind="employee.Group" class="form-control mb-2">
        @foreach (var g in Enum.GetValues<EmployeeGroup>())
        {
            <option value="@g">@GetGroupName(g)</option>
        }
    </select>
    Angerechnete Erfahrung (Monate)<input type="number" @bind="employee.ExperienceMonth" class="form-control mb-2" />
    Arbeitgeber Faktor<input type="number" @bind="employee.BruttoFactor" class="form-control mb-2" />
    @* Erfahrung:<input type="number" @bind="employee.Level" class="form-control mb-1" /> *@
    <button type="button" class="btn btn-primary mt-2" @onclick="Add">Mitarbeiter hinzufügen</button>
</div>

<!-- Feedback für den Benutzer -->
@if (!string.IsNullOrEmpty(message))
{
    <p class="text-info">@message</p>
}

<hr />

@if (employees.Count == 0)
{
    <p>Keine Mitarbeiter vorhanden.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Eingestellt am</th>
                <th>Gruppe</th>
                <th>Vorerfahrung (M.)</th>
                <th>Akt. Stufe</th>
                <th>Nächste Stufe</th>
                <th>Arbeitgeber Faktor</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in employees)
            {
                <tr>
                    <td class="fst-italic">@e.Id</td>
                    @if (editingEmployeeId == e.Id)
                    {
                        <td><input class="form-control" @bind="editEmployeeCopies[e.Id].Name" /></td>
                        <td><input type="date" class="form-control" @bind="editEmployeeCopies[e.Id].HireDate" /></td>
                        <td>
                            <select class="form-control" @bind="editEmployeeCopies[e.Id].Group">
                                @foreach (var g in Enum.GetValues<EmployeeGroup>())
                                {
                                    <option value="@g">@GetGroupName(g)</option>
                                }
                            </select>
                        </td>
                        <td><input type="number" class="form-control" @bind="editEmployeeCopies[e.Id].ExperienceMonth" /></td>
                        <td class="fst-italic">@e.Level</td>
                        <td class="fst-italic">@e.NextLevel.ToShortDateString()</td>
                        <td><input type="number" class="form-control" @bind="editEmployeeCopies[e.Id].BruttoFactor" /></td>
                        <td>
                            <button class="btn btn-sm btn-success me-2" @onclick="() => SaveEmployee(e.Id)">Speichern</button>
                            <button class="btn btn-sm btn-secondary me-2" @onclick="() => CancelEditEmployee(e.Id)">Abbrechen</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(e.Id)">@(expanded.Contains(e.Id) ? "Verstecken" : "Arbeitsverträge zuweisen")</button>
                        </td>
                    }
                    else
                    {
                        <td>@e.Name</td>
                        <td>@e.HireDate.ToShortDateString()</td>
                        <td>@GetGroupName(e.Group)</td>
                        <td>@e.ExperienceMonth</td>
                        <td class="fst-italic">@e.Level</td>
                        <td class="fst-italic">@e.NextLevel.ToShortDateString()</td>
                        <td>@e.BruttoFactor</td>
                        <td>
                            <button type="button" class="btn btn-outline-primary btn-sm me-2" @onclick="() => EditEmployee(e)">Bearbeiten</button>
                            <button type="button" class="btn btn-danger btn-sm me-2" @onclick="@(a => Delete(e))">Löschen</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleExpand(e.Id)">@(expanded.Contains(e.Id) ? "Verstecken" : "Arbeitsverträge zuweisen")</button>
                        </td>
                    }
                </tr>

                @if (expanded.Contains(e.Id))
                {
                    <tr>
                        <td colspan="10" class="p-0 bg-dark-subtle">
                            <div class="p-3 ">
                                @if (!contractsByEmployee.ContainsKey(e.Id) || contractsByEmployee[e.Id].Count == 0)
                                {
                            <em>Keine Arbeitsverträge zugewiesen</em>
                    }
                                    <table class="table-sm">
                                        <thead>
                                            <tr><th>Start</th><th>Ende</th><th>FTE</th><th></th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var c in contractsByEmployee[e.Id].OrderByDescending(c => c.Start))
                                            {
                                                <tr>
                                                    @if (editingContractIds.Contains(c.Id))
                                                    {
                                                        <td><input type="date" class="form-control" @bind="editContractCopies[c.Id].Start" /></td>
                                                        <td><input type="date" class="form-control" @bind="editContractCopies[c.Id].End" /></td>
                                                        <td><input type="number" step="0.1" class="form-control" @bind="editContractCopies[c.Id].Fte" /></td>
                                                        <td>
                                                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveContract(c.Id)">Speichern</button>
                                                            <button class="btn btn-sm btn-secondary" @onclick="() => CancelEditContract(c.Id)">Abbrechen</button>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>@c.Start.ToShortDateString()</td>
                                                        <td>@c.End.ToShortDateString()</td>
                                                        <td>@c.Fte</td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditContract(c)">Bearbeiten</button>
                                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteContract(c.Id)">Löschen</button>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        <tr>
                                            <td>
                                                <input type="date" class="form-control" @bind="contractInputs[e.Id].Start" />
                                            </td>
                                            <td>
                                                <input type="date" class="form-control" @bind="contractInputs[e.Id].End" />
                                            </td>
                                                <td><input type="number" step="0.1" class="form-control" @bind="contractInputs[e.Id].Fte"/></td>
                                                <td>
                                                <button class="btn btn-success" @onclick="() => AddContractForEmployee(e.Id)">Hinzufügen</button>

                                                </td>
                                            
                                        </tr>
                                        </tbody>
                                    </table>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private Employee employee = new()
    {
        HireDate = DateTime.Today,
        BruttoFactor = 1.3M
    };

    private List<Employee> employees = new();
    // contracts grouped by employee id
    private Dictionary<int, List<Contract>> contractsByEmployee = new();
    private class ContractInput
    {
        public DateTime Start { get; set; } = DateTime.Today;
        public DateTime End { get; set; } = DateTime.Today.AddMonths(1);
        public float Fte { get; set; } = 1.0f;
    }
    private Dictionary<int, ContractInput> contractInputs = new();
    private string message = "";
    private HashSet<int> expanded = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        using var db = DbFactory.CreateDbContext();

        employees = await db.Employees
            .OrderByDescending(e => e.HireDate)
            .ToListAsync();

        var allContracts = await db.Contracts.Include(c => c.Employee).OrderByDescending(c => c.Start).ToListAsync();
        contractsByEmployee = allContracts.GroupBy(c => c.EmployeeId).ToDictionary(g => g.Key, g => g.ToList());

        // ensure contractInputs entries exist for each employee
        foreach (var emp in employees)
        {
            if (!contractInputs.ContainsKey(emp.Id))
                contractInputs[emp.Id] = new ContractInput();
            if (!contractsByEmployee.ContainsKey(emp.Id))
                contractsByEmployee[emp.Id] = new List<Contract>();
        }
    }

    private async Task Add()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(employee.Name))
            {
                message = "Name darf nicht leer sein!";
                return;
            }

            using var db = DbFactory.CreateDbContext();

            var toSave = new Employee
            {
                Name = employee.Name,
                Group = employee.Group,
                HireDate = employee.HireDate,
                ExperienceMonth = employee.ExperienceMonth,
                BruttoFactor = employee.BruttoFactor
            };

            db.Employees.Add(toSave);
            await db.SaveChangesAsync();

            message = $"Mitarbeiter '{toSave.Name}' gespeichert!";

            employees.Insert(0, toSave);

            employee = new Employee { HireDate = DateTime.Today, BruttoFactor = 1.3M };
        }
        catch (Exception ex)
        {
            message = ex.ToString(); // wichtig zum Debuggen!
        }
    }

    private async Task Delete(Employee e)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();

            db.Employees.Remove(e);
            await db.SaveChangesAsync();

            message = $"Mitarbeiter '{e.Name}' gelöscht!";

            employees.Remove(e);
            // remove any cached contracts
            contractsByEmployee.Remove(e.Id);
            contractInputs.Remove(e.Id);

        }
        catch (Exception ex)
        {
            message = ex.ToString(); // wichtig zum Debuggen!
        }
    }

    private string GetGroupName(EmployeeGroup group)
    {
        var mem = typeof(EmployeeGroup).GetMember(group.ToString()).FirstOrDefault();
        if (mem != null)
        {
            var disp = mem.GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
                         .OfType<System.ComponentModel.DataAnnotations.DisplayAttribute>()
                         .FirstOrDefault();
            if (disp != null) return disp.Name ?? group.ToString();
        }
        return group.ToString();
    }

    private void ToggleExpand(int employeeId)
    {
        if (!expanded.Remove(employeeId))
        {
            expanded.Add(employeeId);
            if (!contractInputs.ContainsKey(employeeId))
                contractInputs[employeeId] = new ContractInput();
            if (!contractsByEmployee.ContainsKey(employeeId))
                contractsByEmployee[employeeId] = new List<Contract>();
        }
    }

    private async Task AddContractForEmployee(int employeeId)
    {
        if (!contractInputs.TryGetValue(employeeId, out var input))
            return;
        if (input.End < input.Start)
        {
            message = "Ende darf nicht vor dem Start liegen.";
            return;
        }

        try
        {
            using var db = DbFactory.CreateDbContext();
            var toSave = new Contract
            {
                EmployeeId = employeeId,
                Start = input.Start,
                End = input.End,
                Fte = input.Fte
            };
            db.Contracts.Add(toSave);
            await db.SaveChangesAsync();

            var saved = await db.Contracts.Include(c => c.Employee).FirstOrDefaultAsync(c => c.Id == toSave.Id);
            if (saved != null)
            {
                if (!contractsByEmployee.ContainsKey(employeeId)) contractsByEmployee[employeeId] = new List<Contract>();
                contractsByEmployee[employeeId].Insert(0, saved);
            }

            message = "Vertrag gespeichert.";
            contractInputs[employeeId] = new ContractInput();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteContract(int id)
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.Contracts.FindAsync(id);
            if (item != null)
            {
                db.Contracts.Remove(item);
                await db.SaveChangesAsync();

                // remove from local cache
                foreach (var kv in contractsByEmployee)
                {
                    kv.Value.RemoveAll(c => c.Id == id);
                }
                message = "Vertrag gelöscht.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    // --- Inline editing support ---
    private int? editingEmployeeId = null;
    private Dictionary<int, Employee> editEmployeeCopies = new();

    private HashSet<int> editingContractIds = new();
    private Dictionary<int, Contract> editContractCopies = new();

    private void EditEmployee(Employee e)
    {
        editingEmployeeId = e.Id;
        editEmployeeCopies[e.Id] = new Employee
        {
            Id = e.Id,
            Name = e.Name,
            Group = e.Group,
            HireDate = e.HireDate,
            ExperienceMonth = e.ExperienceMonth,
            BruttoFactor = e.BruttoFactor
        };
    }

    private async Task SaveEmployee(int id)
    {
        if (!editEmployeeCopies.TryGetValue(id, out var copy)) return;
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.Employees.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.Name = copy.Name;
                dbItem.Group = copy.Group;
                dbItem.HireDate = copy.HireDate;
                dbItem.ExperienceMonth = copy.ExperienceMonth;
                dbItem.BruttoFactor = copy.BruttoFactor;
                await db.SaveChangesAsync();

                // update local list
                var idx = employees.FindIndex(x => x.Id == id);
                if (idx >= 0)
                {
                    employees[idx].Name = dbItem.Name;
                    employees[idx].Group = dbItem.Group;
                    employees[idx].HireDate = dbItem.HireDate;
                    employees[idx].ExperienceMonth = dbItem.ExperienceMonth;
                    employees[idx].BruttoFactor = dbItem.BruttoFactor;
                }
                message = "Mitarbeiter gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            editEmployeeCopies.Remove(id);
            editingEmployeeId = null;
        }
    }

    private void CancelEditEmployee(int id)
    {
        editEmployeeCopies.Remove(id);
        if (editingEmployeeId == id) editingEmployeeId = null;
    }

    private void EditContract(Contract c)
    {
        editingContractIds.Add(c.Id);
        editContractCopies[c.Id] = new Contract
        {
            Id = c.Id,
            EmployeeId = c.EmployeeId,
            Start = c.Start,
            End = c.End,
            Fte = c.Fte
        };
    }

    private async Task SaveContract(int id)
    {
        if (!editContractCopies.TryGetValue(id, out var copy)) return;
        try
        {
            using var db = DbFactory.CreateDbContext();
            var dbItem = await db.Contracts.FindAsync(id);
            if (dbItem != null)
            {
                dbItem.Start = copy.Start;
                dbItem.End = copy.End;
                dbItem.Fte = copy.Fte;
                await db.SaveChangesAsync();

                // update local cache
                foreach (var kv in contractsByEmployee)
                {
                    var idx = kv.Value.FindIndex(x => x.Id == id);
                    if (idx >= 0)
                    {
                        kv.Value[idx].Start = dbItem.Start;
                        kv.Value[idx].End = dbItem.End;
                        kv.Value[idx].Fte = dbItem.Fte;
                    }
                }
                message = "Vertrag gespeichert.";
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            editContractCopies.Remove(id);
            editingContractIds.Remove(id);
        }
    }

    private void CancelEditContract(int id)
    {
        editContractCopies.Remove(id);
        editingContractIds.Remove(id);
    }
}
